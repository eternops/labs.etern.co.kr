---

---

<div class="relative group">
  <button
    id="theme-toggle-btn"
    class="flex items-center justify-center w-10 h-10 rounded-full bg-panel border border-line text-ink hover:bg-page transition-all cursor-pointer"
    aria-label="테마 변경"
  >
    <!-- Sun Icon (Light) -->
    <svg
      id="sun-icon"
      class="hidden w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      ><path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.95 16.95l.707.707M7.05 7.05l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"
      ></path></svg
    >
    <!-- Moon Icon (Dark) -->
    <svg
      id="moon-icon"
      class="hidden w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      ><path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
      ></path></svg
    >
    <!-- System Icon (Computer) -->
    <svg
      id="system-icon"
      class="hidden w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      ><path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      ></path></svg
    >
  </button>

  <!-- Dropdown Menu -->
  <div
    id="theme-dropdown"
    class="absolute right-0 top-full mt-2 w-36 bg-panel border border-line rounded-xl shadow-xl opacity-0 invisible transition-all z-50 overflow-hidden"
  >
    <button
      data-theme-set="light"
      class="flex items-center gap-3 w-full px-4 py-3 text-sm text-muted hover:text-ink hover:bg-page transition-colors cursor-pointer"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.95 16.95l.707.707M7.05 7.05l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"
        ></path></svg
      >
      <span>라이트</span>
    </button>
    <button
      data-theme-set="dark"
      class="flex items-center gap-3 w-full px-4 py-3 text-sm text-muted hover:text-ink hover:bg-page transition-colors cursor-pointer"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
        ></path></svg
      >
      <span>다크</span>
    </button>
    <button
      data-theme-set="system"
      class="flex items-center gap-3 w-full px-4 py-3 text-sm text-muted hover:text-ink hover:bg-page transition-colors cursor-pointer"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        ></path></svg
      >
      <span>시스템</span>
    </button>
  </div>
</div>

<script>
  const themeToggleButton = document.getElementById('theme-toggle-btn');
  const themeDropdown = document.getElementById('theme-dropdown');

  function applyTheme() {
    const stored = localStorage.getItem('theme') || 'system';
    const isSystemDark = window.matchMedia(
      '(prefers-color-scheme: dark)',
    ).matches;

    // 'system'일 경우 시스템 설정을 따르고, 아니면 저장된 값을 따름
    const isDark = stored === 'dark' || (stored === 'system' && isSystemDark);

    document.documentElement.classList.toggle('dark', isDark);

    // 아이콘 업데이트
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');
    const systemIcon = document.getElementById('system-icon');

    if (sunIcon && moonIcon && systemIcon) {
      sunIcon.classList.add('hidden');
      moonIcon.classList.add('hidden');
      systemIcon.classList.add('hidden');

      if (stored === 'light') sunIcon.classList.remove('hidden');
      else if (stored === 'dark') moonIcon.classList.remove('hidden');
      else systemIcon.classList.remove('hidden');
    }
  }

  // 드롭다운 메뉴 토글
  themeToggleButton?.addEventListener('click', (e) => {
    e.stopPropagation(); // 버튼 클릭 시 문서 클릭 이벤트 전파 방지
    themeDropdown?.classList.toggle('opacity-0');
    themeDropdown?.classList.toggle('invisible');
  });

  // 드롭다운 외부 클릭 시 닫기
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;

    // 드롭다운 내부나 버튼을 클릭한 경우가 아니면 닫기
    if (
      themeDropdown &&
      !themeDropdown.contains(target) &&
      target !== themeToggleButton
    ) {
      themeDropdown.classList.add('opacity-0');
      themeDropdown.classList.add('invisible');
    }
  });

  // 이벤트 위임을 사용하여 클릭 이벤트 처리 (View Transitions 대응)
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;

    const btn = target.closest('[data-theme-set]');
    if (btn) {
      const theme = btn.getAttribute('data-theme-set');
      if (theme) {
        localStorage.setItem('theme', theme);
        applyTheme();
        themeDropdown?.classList.add('opacity-0'); // 테마 선택 후 드롭다운 닫기
        themeDropdown?.classList.add('invisible');
      }
    }
  });

  // 초기 로드 및 시스템 설정 변경 감지
  applyTheme();

  // 시스템 테마 변경 시 즉각 반응하도록 리스너 등록
  window
    .matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', () => {
      // 사용자가 명시적으로 선택한 테마가 없을(system) 때만 반응
      if (
        localStorage.getItem('theme') === 'system' ||
        !localStorage.getItem('theme')
      ) {
        applyTheme();
      }
    });

  // Astro View Transitions 내비게이션 대응
  document.addEventListener('astro:after-swap', applyTheme);
</script>
